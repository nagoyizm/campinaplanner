// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Multi-Tenant: cada cliente es una Organization ─────────────────
model Organization {
  id           String   @id @default(cuid())
  name         String                          // "Cabañas La Campiña"
  slug         String   @unique               // "campina" → campina.planner.cl
  logoUrl      String?
  timezone     String   @default("America/Santiago")
  currency     String   @default("CLP")
  plan         String   @default("starter")   // starter | pro | enterprise
  colorPalette String   @default("verde")     // verde | azul | rojizo | crema | morado | turquesa
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentMethods String @default("Efectivo,Transferencia,Tarjeta de Débito,Tarjeta de Crédito")
  dteOptions     String @default("Boleta Electrónica,Factura Electrónica")
  bankAccounts   String @default("Santander,Scotiabank,Banco de Chile,BE Chequera,BE Rut,BE Turismo,BE Turismo (POS/LP),BCI/MACH,Caja")

  users        User[]
  unitTypes    UnitType[]
  rooms        Room[]
  rates        Rate[]
  guests       Guest[]
  reservations Reservation[]
  amenities    Amenity[]
  auditLogs    AuditLog[]
  saasPayments SaasPayment[]
  memos        Memo[]
  inventoryItems InventoryItem[]
  inventoryTransactions InventoryTransaction[]
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  password       String
  role           String   @default("operator") // superadmin | admin | operator | observer
  roleName       String   @default("Recepción")
  permissions    String?  @db.Text
  active         Boolean  @default(true)
  organizationId String   @default("seed-org-campina")
  defaultHomePage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  notifyWspResConf    Boolean @default(false)
  notifyEmailResConf  Boolean @default(false)
  notifyWspCheckOut   Boolean @default(false)
  notifyEmailCheckOut Boolean @default(false)
  notifyWspCleaning   Boolean @default(false)
  notifyEmailCleaning Boolean @default(false)
  notifyWspInvAlert   Boolean @default(false)
  notifyEmailInvAlert Boolean @default(false)

  organization Organization  @relation(fields: [organizationId], references: [id])
  checkIns     Reservation[] @relation("CheckInStaff")
  checkOuts    Reservation[] @relation("CheckOutStaff")
  auditLogs    AuditLog[]
  targetedMemos Memo[]       @relation("TargetUser")

  @@index([organizationId])
}

model Guest {
  id             String   @id @default(cuid())
  organizationId String   @default("seed-org-campina")
  firstName      String
  lastName       String
  rut            String?
  email          String?
  phone          String?
  nationality    String?  @default("Chile")
  address        String?
  notes          String?
  referral       String?
  tags           String   @default("") // JSON array stored as string: ["VIP","ruidoso"]
  totalStays     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  reservations Reservation[]

  @@index([organizationId])
}

model UnitType {
  id             String   @id @default(cuid())
  organizationId String   @default("seed-org-campina")
  name           String   // "Cabaña 5P", "Suite Deluxe"
  description    String?
  maxOccupancy   Int      @default(2)
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  rooms        Room[]
  rates        Rate[]

  @@index([organizationId])
}

model Room {
  id             String    @id @default(cuid())
  organizationId String    @default("seed-org-campina")
  code           String    // "C1", "S1" — único por org
  name           String    // "Cabaña 1", "Suite Std 1"
  unitTypeId     String
  defaultRateId  String?
  active         Boolean   @default(true)
  cleaningStatus String    @default("clean") // 'clean', 'dirty', 'maintenance'
  cleaningPriority Boolean @default(false)
  cleaningNote   String?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  unitType         UnitType          @relation(fields: [unitTypeId], references: [id])
  defaultRate      Rate?             @relation("DefaultRate", fields: [defaultRateId], references: [id])
  reservationRooms ReservationRoom[]

  @@unique([code, organizationId]) // ponytail: two orgs can share "C1"
  @@index([organizationId])
  @@index([unitTypeId])
  @@index([defaultRateId])
}

model Rate {
  id                   String    @id @default(cuid())
  organizationId       String    @default("seed-org-campina")
  name                 String    // "Cabaña 5P Temporada Alta"
  unitTypeId           String?
  rackRate             Float     @default(0)
  extraPersonAdult     Float     @default(0)
  extraPersonChild     Float     @default(0)
  weekendSurcharge     Float     @default(0)
  includedOccupants    Int       @default(2)
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  unitType         UnitType?         @relation(fields: [unitTypeId], references: [id])
  defaultForRooms  Room[]            @relation("DefaultRate")
  reservationRooms ReservationRoom[]

  @@index([organizationId])
  @@index([unitTypeId])
}

model Reservation {
  id                Int       @id @default(autoincrement())
  organizationId    String    @default("seed-org-campina")
  guestId           String
  status            String    @default("booked")
  // booked | confirmed | checked_in | checked_out | blocked | cancelled | no_show

  isVip             Boolean   @default(false)
  isNoisy           Boolean   @default(false)
  isDirty           Boolean   @default(false)
  isDifficult       Boolean   @default(false)
  isNewPax          Boolean   @default(true)
  isRecurring       Boolean   @default(false)
  isWalkIn          Boolean   @default(false)
  lateCheckoutHrs   Int?
  earlyCheckinHrs   Int?

  adults            Int       @default(1)
  children          Int       @default(0)
  pets              Int       @default(0)

  checkInStaffId    String?
  checkOutStaffId   String?

  paymentMethod     String?
  accountCode       String?

  unitTotal         Float     @default(0)
  extraPersonCharge Float     @default(0)
  discounts         Float     @default(0)
  additionalServices Float    @default(0)
  tax               Float     @default(0)
  totalPaid         Float     @default(0)

  lostItems         String?
  notes             String?
  dte               String?
  guaranteeRsv      String?
  guaranteeGames    String?

  createdByName     String?
  source            String    @default("Directa")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization    Organization      @relation(fields: [organizationId], references: [id])
  guest           Guest             @relation(fields: [guestId], references: [id])
  checkInStaff    User?             @relation("CheckInStaff", fields: [checkInStaffId], references: [id])
  checkOutStaff   User?             @relation("CheckOutStaff", fields: [checkOutStaffId], references: [id])
  rooms           ReservationRoom[]
  payments        Payment[]
  extras          Extra[]
  auditLogs       AuditLog[]

  @@index([organizationId])
  @@index([guestId])
  @@index([checkInStaffId])
  @@index([checkOutStaffId])
}

model ReservationRoom {
  id            String    @id @default(cuid())
  reservationId Int
  roomId        String
  rateId        String?

  arrival       DateTime
  departure     DateTime
  nights        Int       @default(1)
  adults        Int       @default(1)
  children      Int       @default(0)
  unitRate      Float     @default(0)
  unitTotal     Float     @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  room          Room        @relation(fields: [roomId], references: [id])
  rate          Rate?       @relation(fields: [rateId], references: [id])

  @@index([reservationId])
  @@index([roomId])
  @@index([rateId])
}

model Payment {
  id            String    @id @default(cuid())
  reservationId Int
  amount        Float
  method        String    // efectivo | transferencia | tarjeta_debito | tarjeta_credito | cheque | otro
  reference     String?
  date          DateTime  @default(now())
  notes         String?
  createdAt     DateTime  @default(now())

  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

model Extra {
  id            String    @id @default(cuid())
  reservationId Int
  amenityId     String?
  name          String
  quantity      Int       @default(1)
  unitPrice     Float
  total         Float
  date          DateTime  @default(now())
  notes         String?

  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  amenity       Amenity?    @relation(fields: [amenityId], references: [id])

  @@index([reservationId])
  @@index([amenityId])
}

model Amenity {
  id             String    @id @default(cuid())
  organizationId String    @default("seed-org-campina")
  name           String
  category       String?   // "Alimentos", "Servicios", "Equipamiento"
  price          Float     @default(0)
  unit           String?   // "por noche", "por persona", "unidad"
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  extras       Extra[]

  @@index([organizationId])
}

model AuditLog {
  id             String    @id @default(cuid())
  organizationId String    @default("seed-org-campina")
  reservationId  Int?
  userId         String?
  action         String    // created | updated | status_changed | payment_added | etc.
  details        String?
  timestamp      DateTime  @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id])
  reservation   Reservation?  @relation(fields: [reservationId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([reservationId])
  @@index([userId])
}

model Memo {
  id             String   @id @default(cuid())
  organizationId String
  content        String
  author         String   @default("Administración")
  targetUserId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  targetUser   User?        @relation("TargetUser", fields: [targetUserId], references: [id])

  @@index([organizationId])
  @@index([targetUserId])
}

// ── SaaS SuperAdmin Models ──────────────────────────────────────
model SaasPayment {
  id             String       @id @default(cuid())
  organizationId String
  amount         Float
  startDate      DateTime
  endDate        DateTime
  paidAt         DateTime?
  status         String       @default("pending") // pending | paid | overdue
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model SaasEvent {
  id          String   @id @default(cuid())
  title       String
  startDate   DateTime
  endDate     DateTime
  description String?
  type        String   @default("reminder") // meeting | reminder | maintenance
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppSession {
  id    String @id
  data  String @db.Text
}

model InventoryItem {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  category        String   // Ej: 'Limpieza', 'Amenidades', etc.
  unitCost        Float    // Costo base actual
  currentQuantity Int      @default(0)
  minQuantity     Int      @default(0) // Útil a futuro para alertas de stock bajo
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization           @relation(fields: [organizationId], references: [id])
  transactions    InventoryTransaction[]

  @@index([organizationId])
}

model InventoryTransaction {
  id              String   @id @default(cuid())
  organizationId  String
  itemId          String
  type            String   // 'purchase' (compra), 'usage' (uso/merma), 'adjustment' (ajuste manual)
  quantityChange  Int      // Positivo (compras) o Negativo (usos)
  unitCost        Float    // Costo al momento de la transacción
  totalCost       Float    // (quantityChange * unitCost). Sirve para sumar gastos.
  date            DateTime @default(now())
  notes           String?
  userId          String?  // Quién hizo el registro

  item            InventoryItem @relation(fields: [itemId], references: [id])
  organization    Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([itemId])
}
